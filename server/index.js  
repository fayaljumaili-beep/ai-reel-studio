import express from "express";
import cors from "cors";
import fs from "fs";
import path from "path";
import ffmpeg from "fluent-ffmpeg";
import ffmpegPath from "ffmpeg-static";
import OpenAI from "openai";
import axios from "axios";

ffmpeg.setFfmpegPath(ffmpegPath);

const app = express();

// 🔐 API clients
const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

app.use(cors());
app.use(express.json());

// ✅ Health check
app.get("/", (req, res) => {
  res.send("Server running 🚀");
});

// 🧠 Generate script
async function generateScript(idea) {
  const res = await openai.chat.completions.create({
    model: "gpt-4o-mini",
    messages: [
      {
        role: "system",
        content:
          "You write short viral motivational scripts for TikTok. Max 2 sentences. Very powerful.",
      },
      {
        role: "user",
        content: idea,
      },
    ],
  });

  return res.choices[0].message.content;
}

// 🎤 Generate voice
async function generateVoice(script) {
  const response = await axios({
    method: "POST",
    url: "https://api.elevenlabs.io/v1/text-to-speech/YOUR_VOICE_ID",
    headers: {
      "xi-api-key": process.env.ELEVENLABS_API_KEY,
      "Content-Type": "application/json",
    },
    data: {
      text: script,
      model_id: "eleven_monolingual_v1",
    },
    responseType: "arraybuffer",
  });

  const audioPath = path.join("server/assets", "voice.mp3");
  fs.writeFileSync(audioPath, response.data);

  return audioPath;
}

// 🎬 MAIN ROUTE
app.post("/generate-video", async (req, res) => {
  try {
    const idea = req.body.script;

    if (!idea) {
      return res.status(400).json({ error: "No idea provided" });
    }

    console.log("Idea:", idea);

    // 1. AI script
    const script = await generateScript(idea);
    console.log("Generated script:", script);

    // 2. AI voice
    const audioPath = await generateVoice(script);

    // 3. File paths
    const imagePath = path.join("server/assets", "image.jpg");
    const outputPath = path.join(
      "server",
      `output-${Date.now()}.mp4`
    );

    let responded = false;

    // 4. FFmpeg video
    ffmpeg()
      .input(imagePath)
      .inputOptions(["-loop 1"])
      .input(audioPath)
      .videoCodec("libx264")
      .audioCodec("aac")
      .outputOptions([
        "-pix_fmt yuv420p",
        "-shortest",
        "-movflags +faststart",
      ])

      .on("error", (err) => {
        console.error("FFmpeg error:", err);
        if (!responded) {
          responded = true;
          res.status(500).json({ error: "FFmpeg failed" });
        }
      })

      .on("end", () => {
        console.log("Video created:", outputPath);

        if (!responded) {
          responded = true;

          const videoUrl = `https://ai-reel-studio-production.up.railway.app/${path.basename(outputPath)}`;

          res.json({ videoUrl, script });

          // 🧹 cleanup after 5 min
          setTimeout(() => {
            try {
              if (fs.existsSync(outputPath)) fs.unlinkSync(outputPath);
              if (fs.existsSync(audioPath)) fs.unlinkSync(audioPath);
            } catch (e) {
              console.log("Cleanup error:", e.message);
            }
          }, 300000);
        }
      })

      .save(outputPath);

  } catch (err) {
    console.error("SERVER ERROR:", err);
    res.status(500).json({
      error: "Video generation failed",
      details: err.message,
    });
  }
});

// ✅ Serve files
app.use(express.static("server"));

// ✅ Start server
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log(`🚀 Server running on port ${PORT}`);
});